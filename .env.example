# Cloud runtime. Copy values into the shell environment; do not commit real keys.
SUBTITLE_STUDIO_MODE=cloud
SUBTITLE_STUDIO_DATA_DIR=/root/autodl-tmp/subtitle-studio-data
SUBTITLE_STUDIO_HOST=127.0.0.1
SUBTITLE_STUDIO_PORT=6006

# Optional protection when you intentionally bind to a remotely reachable interface.
SUBTITLE_STUDIO_USERNAME=
SUBTITLE_STUDIO_PASSWORD=

# Provider keys are read from environment variables and are never persisted on cloud Linux.
SUBTITLE_ASR_API_KEY=
SUBTITLE_TRANSLATOR_API_KEY=
SUBTITLE_REVIEWER_API_KEY=
